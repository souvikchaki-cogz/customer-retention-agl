# ──────────────── Azure SQL (shared by all components) ────────────────
AZSQL_SERVER=myserver.database.windows.net
AZSQL_DB=retentiondb
AZSQL_DRIVER={ODBC Driver 18 for SQL Server}

# ──────────────── Azure OpenAI ────────────────
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
AZURE_OPENAI_API_KEY=replace_me
AZURE_OPENAI_DEPLOYMENT=your-gpt-deployment
AZURE_OPENAI_DEPLOYMENTNAME=${AZURE_OPENAI_DEPLOYMENT}
AZURE_OPENAI_API_ENDPOINT=${AZURE_OPENAI_ENDPOINT}

# ──────────────── Functions / Agent ────────────────
REPLAY_QUEUE_NAME=event-replay
APPINSIGHTS_INSTRUMENTATIONKEY=<guid>
AGENT_VERSION=v1
LEAD_SCORE_THRESHOLD=0.7
CONFIDENCE_FLOOR=0.60
EVIDENCE_MIN_LEN=4
USE_SQL_RULES=0

# ──────────────── Webapp ────────────────
LOG_LEVEL=INFO
# Set FUNCTION_START_URL only if Functions are deployed separately;
# leave blank to use in-process orchestration.
FUNCTION_START_URL=