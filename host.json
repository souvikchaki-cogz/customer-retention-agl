{
  "version": "2.0",
  "extensionBundle": {
    "id": "Microsoft.Azure.Functions.ExtensionBundle",
    "version": "[3.*, 4.0.0)"
  },
  "extensions": {
    "queues": { "batchSize": 16, "newBatchThreshold": 8 },
    "durableTask": {
      "hubName": "RetentionHub"
    }
  },
  "logging": {
    "applicationInsights": {
      "samplingSettings": { "isEnabled": true },
      "enableLiveMetricsFilters": true
    }
  }
}